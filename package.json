{
  "name": "pomello",
  "version": "1.0.0-alpha.0",
  "description": "The Pomodoro App for Doers",
  "homepage": "https://pomelloapp.com",
  "license": "UNLICENSED",
  "author": "Tiny Nudge LLC <pomello@tinynudge.co>",
  "main": "packages/main/dist/index.cjs",
  "type": "module",
  "scripts": {
    "build:main": "vite build --config packages/main/vite.config.js",
    "build:preload": "vite build --config packages/preload/vite.config.js",
    "build:renderer": "vite build --config packages/renderer/vite.config.js",
    "build": "run-p build:main build:preload build:renderer",
    "compile": "electron-builder --config .electron-builder.config.cjs --dir --config.asar=false",
    "format:check": "prettier --check 'packages/**/*.{js,jsx,ts,svelte}'",
    "format": "prettier --write 'packages/**/*.{js,ts,svelte,json,md,yml}'",
    "lint:scripts": "eslint . --ext .js,.ts,.svelte",
    "lint:styles": "stylelint **/*.svelte",
    "lint": "run-p lint:scripts lint:styles",
    "release": "standard-version",
    "start": "node scripts/start.js",
    "test:renderer": "vitest --root packages/renderer",
    "test": "run-p test:renderer",
    "check:main": "tsc --noEmit --project packages/main",
    "check:preload": "tsc --noEmit --project packages/preload",
    "check:renderer": "svelte-check",
    "check": "run-p --continue-on-error check:main check:preload check:renderer",
    "update:vendors": "node scripts/update-electron-vendors.js"
  },
  "dependencies": {
    "@tinynudge/pomello-service": "^0.1.19",
    "ajv": "^8.12.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.1",
    "throttle-debounce": "^5.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^2.4.2",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/svelte": "^4.0.3",
    "@tsconfig/svelte": "^5.0.0",
    "@types/throttle-debounce": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/ui": "^0.33.0",
    "electron": "^25.3.0",
    "electron-builder": "^23.1.0",
    "electron-builder-notarize": "^1.5.1",
    "electron-devtools-installer": "^3.2.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-svelte": "^2.32.2",
    "jsdom": "^22.1.0",
    "npm-run-all": "^4.1.5",
    "postcss-html": "^1.5.0",
    "prettier": "^2.8.8",
    "prettier-plugin-svelte": "^2.10.1",
    "standard-version": "^9.5.0",
    "stylelint": "^15.10.2",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-idiomatic-order": "^9.0.0",
    "stylelint-config-prettier": "^9.0.5",
    "svelte": "^4.0.5",
    "svelte-check": "^3.4.6",
    "tslib": "^2.6.0",
    "typescript": "^5.1.6",
    "vite": "^4.4.4",
    "vitest": "^0.33.0"
  },
  "private": true
}
